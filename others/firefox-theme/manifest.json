{
  "manifest_version": 3,
  "name": "fridge.dev Blackprint",
  "version": "1.0.2",
  "description": "A calm Firefox theme based on fridge.dev's blackprint purple-to-teal gradient and compact clickable-object styling.",
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-theme@fridge.dev",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "theme": {
    "images": {
      "theme_frame": "theme-frame.svg"
    },
    "colors": {
      "frame": "#111419",
      "frame_inactive": "#16191d",
      "tab_background_text": "#bfc9cb",
      "tab_selected": "#111518",
      "tab_text": "#eeeeee",
      "tab_line": "#6caaa7",
      "tab_loading": "#8b73a8",
      "toolbar": "#101417",
      "toolbar_text": "#eeeeee",
      "toolbar_field": "#0b0d0f",
      "toolbar_field_text": "#eeeeee",
      "toolbar_field_focus": "#111518",
      "toolbar_field_text_focus": "#ffffff",
      "toolbar_field_border": "#2e5961",
      "toolbar_field_border_focus": "#6caaa7",
      "toolbar_field_highlight": "#776490",
      "toolbar_field_highlight_text": "#ffffff",
      "toolbar_top_separator": "#26383d",
      "toolbar_bottom_separator": "#243034",
      "toolbar_vertical_separator": "#2f444a",
      "button_background_hover": "#1d2a31",
      "button_background_active": "#263f49",
      "icons": "#d8e4e3",
      "icons_attention": "#82bfbc",
      "bookmark_text": "#d8e4e3",
      "popup": "#111518",
      "popup_text": "#eeeeee",
      "popup_border": "#345e68",
      "popup_highlight": "#203840",
      "popup_highlight_text": "#ffffff",
      "sidebar": "#111518",
      "sidebar_text": "#eeeeee",
      "sidebar_border": "#2e5961",
      "sidebar_highlight": "#223c42",
      "sidebar_highlight_text": "#ffffff",
      "ntp_background": "#111419",
      "ntp_text": "#eeeeee",
      "ntp_card_background": "#15191b"
    },
    "properties": {
      "color_scheme": "dark",
      "content_color_scheme": "dark"
    }
  }
}
