server {
    listen 443 ssl; # managed by Certbot
    server_name fridge.dev www.fridge.dev m.fridge.dev;

    ssl_certificate /etc/letsencrypt/live/fridge.dev/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/fridge.dev/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/fridge.dev;
    index index.html index.php;
    client_max_body_size 20M;

    # Check the editable hard-ban list before serving website pages or files.
    # A 401 from the internal checker becomes a server-side redirect to the
    # only public route exempted from this access check.
    auth_request /_hard-ban-check;
    error_page 401 = @hard-ban-redirect;

    location @hard-ban-redirect {
        auth_request off;
        return 302 /error/blacklisted;
    }

    location = /_hard-ban-check {
        internal;
        auth_request off;
        # auth_request does not forward the parent request body. Clear its
        # body metadata as well so PHP-FPM does not wait for a POST body that
        # can never arrive.
        fastcgi_pass_request_body off;
        fastcgi_pass unix:/run/php-fpm/php-fpm.sock;
        include fastcgi_params;
        fastcgi_param CONTENT_LENGTH "";
        fastcgi_param REQUEST_METHOD GET;
        fastcgi_param SCRIPT_FILENAME $document_root/api/hard-ban-check/index.php;
    }

    # The checker is callable only through nginx's internal subrequest.
    location ^~ /api/hard-ban-check/ {
        return 404;
    }

    # Hard-banned clients may access this page and its local, self-contained
    # templates, but nothing else on the website.
    location = /error/blacklisted {
        auth_request off;
        rewrite ^ /error/blacklisted/index.php last;
    }

    location = /error/blacklisted/index.php {
        auth_request off;
        fastcgi_pass unix:/run/php-fpm/php-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root/error/blacklisted/index.php;
        include fastcgi_params;
    }

    location /error/blacklisted/ {
        auth_request off;
        try_files $uri $uri/ =404;
    }

    # The blacklist response may load only font assets from the shared resource directory.
    location ~* ^/resources/.*\.(?:woff2?|ttf|otf)$ {
        auth_request off;
        try_files $uri =404;
    }

    location ~ \.php$ {
        root /var/www/fridge.dev;
        fastcgi_pass unix:/run/php-fpm/php-fpm.sock;  # adjust if your PHP-FPM socket differs
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }
	
	# Allow public access to the off-topic archive JSON
    location = /data/etc/off-topic-archive.json {
        try_files $uri =404;
    }

    # Guestbook entries contain IP metadata and must only be read through PHP
    location = /data/guestbook {
        return 403;
    }

    location ^~ /data/guestbook/ {
        return 403;
    }

    # Only block other JSON files in /data/
    location ~* ^/data/.*\.json$ { return 403; }

    # Never serve contact submissions or rate-limit data directly
    location ^~ /data/contact/ {
        return 403;
    }

    # Operational IP denylist; never expose it as a data file.
    location = /data/etc/hard-banned-ips.txt {
        return 403;
    }

    location = /data/etc/hard-ban-identities.json {
        return 403;
    }

    location = /data/etc/banlists {
        return 403;
    }

    location ^~ /data/etc/banlists/ {
        return 403;
    }

    # Feed clean URLs
    location ~ ^/feed/posts/[^/]+$ {
        rewrite ^/feed/posts/(.+)$ /feed/posts/index.php?post=$1 last;
    }
    location /feed/posts/ { try_files $uri $uri/ /feed/posts/index.php?$args; }
    location /feed/       { try_files $uri $uri/ /feed/index.php?$args; }

    # Avoid trailing-slash redirects on edit/create that drop POST bodies
    location = /feed/edit   { rewrite ^ /feed/edit/index.php?$args last; }
    location = /feed/create { rewrite ^ /feed/create/index.php?$args last; }

    # Journal clean URLs
    location ~ ^/journal/posts/[^/]+$ {
        rewrite ^/journal/posts/(.+)$ /journal/posts/index.php?post=$1 last;
    }
    location /journal/    { try_files $uri $uri/ /journal/index.php?$args; }

    location = /journal/create { rewrite ^ /journal/create/index.php?$args last; }
	
    # Retired email/newsletter routes
    location = /email {
        return 301 /contact;
    }

    location ^~ /email/ {
        return 301 /contact;
    }

    # Contact route: avoid trailing-slash redirects on POST
    location = /contact {
        rewrite ^ /contact/index.php?$args last;
    }

    location /contact/ {
        try_files $uri $uri/ /contact/index.php?$args;
    }

    # Admin hard-ban editor: preserve POST bodies on the no-slash route.
    location = /settings/banned-ips {
        rewrite ^ /settings/banned-ips/index.php?$args last;
    }

    # Account routes: avoid trailing-slash redirects on POST
    location ~ ^/account/(login|create|change-password|password|email|link-discord)/?$ {
        rewrite ^/account/(login|create|change-password|password|email|link-discord)/?$ /account/$1/index.php?$args last;
    }

    location ~ ^/account/admin/edit/?$ {
        rewrite ^/account/admin/edit/?$ /account/admin/edit/index.php?$args last;
    }
	
	# Guestbook clean URLs
    location ~ ^/guestbook/posts/[^/]+$ {
        rewrite ^/guestbook/posts/(.+)$ /guestbook/posts/index.php?post=$1 last;
    }
    location /guestbook/    { try_files $uri $uri/ /guestbook/index.php?$args; }

    # Avoid trailing-slash redirects on edit/create that drop POST bodies
    location = /guestbook/edit   { rewrite ^ /guestbook/edit/index.php?$args last; }
    location = /guestbook/create { rewrite ^ /guestbook/create/index.php?$args last; }

    # API endpoints: rewrite to index.php to prevent 301 slash redirects on POST
    location ~ ^/api/(bookmark|dev-bootstrap|feed-post|settings|toast-feed-generate)/?$ {
        rewrite ^/api/(bookmark|dev-bootstrap|feed-post|settings|toast-feed-generate)/?$ /api/$1/index.php?$args last;
    }
    location ~ ^/api/account/is-admin/?$ {
        rewrite ^/api/account/is-admin/?$ /api/account/is-admin/index.php?$args last;
    }

    # mdpaste clean URLs
    location ~ "^/tools/mdpaste/s/[a-fA-F0-9]{16}/?$" {
        rewrite "^/tools/mdpaste/s/([a-fA-F0-9]{16})/?$" /tools/mdpaste/s/index.php?id=$1 last;
    }

    location /tools/mdpaste/s/ {
        try_files $uri $uri/ /tools/mdpaste/s/index.php?$args;
    }

    location /tools/mdpaste/ {
        try_files $uri $uri/ /tools/mdpaste/index.php?$args;
    }

    # Upload route API: avoid trailing-slash redirects that drop POST bodies
    location = /tools/upload {
        rewrite ^ /tools/upload/index.php?$args last;
    }

    location /tools/upload/ {
        try_files $uri $uri/ /tools/upload/index.php?$args;
    }

    # Chat clean URLs + POST-safe dashboard route
    location = /chat {
        rewrite ^ /chat/index.php?$args last;
    }

    location ~ "^/chat/([a-z0-9]{9}|[a-fA-F0-9]{32})/?$" {
        rewrite "^/chat/([a-z0-9]{9}|[a-fA-F0-9]{32})/?$" /chat/index.php?id=$1 last;
    }

    location /chat/ {
        try_files $uri $uri/ /chat/index.php?$args;
    }

    # Never serve encrypted chat data, keys, or attachments directly
    location ^~ /data/chat/ {
        return 403;
    }


    # Fallback
    location / { try_files $uri $uri/ /index.php?$args; }

    # Custom error redirects
    error_page 403 /error/403;
    error_page 404 /error/404;
    error_page 500 502 503 504 /error/50x;

    location = /error/403 { root /var/www/fridge.dev; }
    location = /error/404 { root /var/www/fridge.dev; }
    location = /error/50x { root /var/www/fridge.dev; }





}

server {
    if ($host = m.fridge.dev) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name fridge.dev www.fridge.dev m.fridge.dev;
    if ($host = www.fridge.dev) { return 301 https://$host$request_uri; }
    if ($host = fridge.dev)     { return 301 https://$host$request_uri; }
    return 404; # managed by Certbot
}
